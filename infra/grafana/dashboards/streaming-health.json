{
  "uid": "streaming-health",
  "title": "Streaming — Health",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "1m",
  "time": {
    "from": "now-1h",
    "to": "now"
  },
  "timepicker": {},
  "panels": [
    {
      "id": 1,
      "type": "timeseries",
      "title": "Messages Received / min",
      "description": "Count of Redpanda messages consumed by pnl-consumer per minute, derived from CloudWatch log metric filter on the 'Received ' log pattern.",
      "gridPos": {
        "x": 0,
        "y": 0,
        "w": 24,
        "h": 8
      },
      "datasource": {
        "type": "cloudwatch",
        "uid": "cloudwatch"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "displayName": "msg/min",
          "color": {
            "mode": "palette-classic"
          },
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 10,
            "gradientMode": "none",
            "spanNulls": false
          }
        }
      },
      "options": {
        "tooltip": {
          "mode": "single",
          "sort": "none"
        },
        "legend": {
          "displayMode": "list",
          "placement": "bottom"
        }
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "cloudwatch",
            "uid": "cloudwatch"
          },
          "region": "ap-northeast-1",
          "namespace": "trading-analysis",
          "metricName": "MessagesReceived",
          "statistics": ["Sum"],
          "period": "60",
          "matchExact": true,
          "dimensions": {}
        }
      ]
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "Messages Published / min",
      "description": "Count of Binance candles published to Redpanda by ws-consumer per minute, derived from CloudWatch log metric filter on the 'Published ' log pattern.",
      "gridPos": {
        "x": 0,
        "y": 8,
        "w": 24,
        "h": 8
      },
      "datasource": {
        "type": "cloudwatch",
        "uid": "cloudwatch"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "displayName": "msg/min",
          "color": {
            "mode": "palette-classic"
          },
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 10,
            "gradientMode": "none",
            "spanNulls": false
          }
        }
      },
      "options": {
        "tooltip": {
          "mode": "single",
          "sort": "none"
        },
        "legend": {
          "displayMode": "list",
          "placement": "bottom"
        }
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "cloudwatch",
            "uid": "cloudwatch"
          },
          "region": "ap-northeast-1",
          "namespace": "trading-analysis",
          "metricName": "MessagesPublished",
          "statistics": ["Sum"],
          "period": "60",
          "matchExact": true,
          "dimensions": {}
        }
      ]
    },
    {
      "id": 3,
      "type": "timeseries",
      "title": "ClickHouse Sink Flushes / min",
      "description": "Count of ClickHouse insert flushes per minute per sink (prod, real_trade, bt), derived from CloudWatch log metric filters on the 'ClickHouseSink <sink>' log pattern.",
      "gridPos": {
        "x": 0,
        "y": 16,
        "w": 24,
        "h": 8
      },
      "datasource": {
        "type": "cloudwatch",
        "uid": "cloudwatch"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": {
            "mode": "palette-classic"
          },
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 10,
            "gradientMode": "none",
            "spanNulls": false
          }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "prod" },
            "properties": [{ "id": "displayName", "value": "prod" }]
          },
          {
            "matcher": { "id": "byName", "options": "real_trade" },
            "properties": [{ "id": "displayName", "value": "real_trade" }]
          },
          {
            "matcher": { "id": "byName", "options": "bt" },
            "properties": [{ "id": "displayName", "value": "bt" }]
          }
        ]
      },
      "options": {
        "tooltip": {
          "mode": "multi",
          "sort": "none"
        },
        "legend": {
          "displayMode": "list",
          "placement": "bottom"
        }
      },
      "targets": [
        {
          "refId": "A",
          "alias": "prod",
          "datasource": {
            "type": "cloudwatch",
            "uid": "cloudwatch"
          },
          "region": "ap-northeast-1",
          "namespace": "trading-analysis",
          "metricName": "ClickHouseSinkProd",
          "statistics": ["Sum"],
          "period": "60",
          "matchExact": true,
          "dimensions": {}
        },
        {
          "refId": "B",
          "alias": "real_trade",
          "datasource": {
            "type": "cloudwatch",
            "uid": "cloudwatch"
          },
          "region": "ap-northeast-1",
          "namespace": "trading-analysis",
          "metricName": "ClickHouseSinkRealTrade",
          "statistics": ["Sum"],
          "period": "60",
          "matchExact": true,
          "dimensions": {}
        },
        {
          "refId": "C",
          "alias": "bt",
          "datasource": {
            "type": "cloudwatch",
            "uid": "cloudwatch"
          },
          "region": "ap-northeast-1",
          "namespace": "trading-analysis",
          "metricName": "ClickHouseSinkBt",
          "statistics": ["Sum"],
          "period": "60",
          "matchExact": true,
          "dimensions": {}
        }
      ]
    },
    {
      "id": 4,
      "type": "timeseries",
      "title": "Redpanda ECS — CPU Utilization",
      "description": "CPU utilization % for the trading-analysis-redpanda ECS Fargate service (1 vCPU task).",
      "gridPos": {
        "x": 0,
        "y": 24,
        "w": 12,
        "h": 8
      },
      "datasource": {
        "type": "cloudwatch",
        "uid": "cloudwatch"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "color": {
            "mode": "palette-classic"
          },
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 10,
            "gradientMode": "none",
            "spanNulls": false
          }
        }
      },
      "options": {
        "tooltip": {
          "mode": "single",
          "sort": "none"
        },
        "legend": {
          "displayMode": "list",
          "placement": "bottom"
        }
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "cloudwatch",
            "uid": "cloudwatch"
          },
          "region": "ap-northeast-1",
          "namespace": "AWS/ECS",
          "metricName": "CPUUtilization",
          "statistics": ["Average"],
          "period": "60",
          "matchExact": true,
          "dimensions": {
            "ClusterName": "trading-analysis",
            "ServiceName": "trading-analysis-redpanda"
          }
        }
      ]
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "Redpanda ECS — Memory Utilization",
      "description": "Memory utilization % for the trading-analysis-redpanda ECS Fargate service (2 GB task, 1500M allocated to Redpanda).",
      "gridPos": {
        "x": 12,
        "y": 24,
        "w": 12,
        "h": 8
      },
      "datasource": {
        "type": "cloudwatch",
        "uid": "cloudwatch"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "color": {
            "mode": "palette-classic"
          },
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 10,
            "gradientMode": "none",
            "spanNulls": false
          }
        }
      },
      "options": {
        "tooltip": {
          "mode": "single",
          "sort": "none"
        },
        "legend": {
          "displayMode": "list",
          "placement": "bottom"
        }
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "cloudwatch",
            "uid": "cloudwatch"
          },
          "region": "ap-northeast-1",
          "namespace": "AWS/ECS",
          "metricName": "MemoryUtilization",
          "statistics": ["Average"],
          "period": "60",
          "matchExact": true,
          "dimensions": {
            "ClusterName": "trading-analysis",
            "ServiceName": "trading-analysis-redpanda"
          }
        }
      ]
    }
  ]
}
