# ClickHouse Cloud
CLICKHOUSE_HOST=xxx.clickhouse.cloud
CLICKHOUSE_PORT=8443
CLICKHOUSE_USER=default
CLICKHOUSE_PASSWORD=
CLICKHOUSE_SECURE=true

# Dagster Postgres (metadata storage)
DAGSTER_PG_HOST=localhost
DAGSTER_PG_PORT=5432
DAGSTER_PG_USERNAME=dagster
DAGSTER_PG_PASSWORD=dagster
DAGSTER_PG_DATABASE=dagster

# AWS
AWS_DEFAULT_REGION=ap-southeast-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
S3_BUCKET=trading-analysis-data

# Binance API (public, no key needed for market data)
BINANCE_BASE_URL=https://fapi.binance.com
